{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "ink-surface-sdk": ["packages/ink-surface-sdk/src/index.ts"]
    },
    "types": ["vite/client", "node"]
  },
  "include": ["src", "packages/ink-surface-sdk/src", "scripts/**/*.ts"]
}
