{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": false },
  "formatter": { "enabled": false },
  "json": { "parser": { "allowComments": true } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      },
      "suspicious": {
        "noDoubleEquals": "warn",
        "noDebugger": "error"
      }
    }
  },
  "files": {
    "ignore": [
      "dist",
      ".inkloop-smoke-runs",
      "node_modules",
      "examples/ai-annotation-demo/dist",
      "examples/ai-annotation-demo/.inkloop-smoke-runs",
      "examples/ai-annotation-demo/android",
      "examples/ai-annotation-demo/legacy",
      "examples/ai-annotation-demo/public",
      "examples/ai-annotation-demo/mobile.html",
      "**/*.mjs"
    ]
  }
}
