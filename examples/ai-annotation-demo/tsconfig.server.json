{
  // Node 侧（server/ 代理 + vite.config + 构建脚本）的类型检查。
  // app tsconfig.json 只 include src，server/vite/scripts 此前完全漏检（见审计 §6.1）。
  // .mjs 用 allowJs 让 ts 文件能解析 import，但 checkJs:false 不深查 JS 内部，避免噪音。
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "ink-surface-sdk": ["../../src/index.ts"],
      "ink-surface-sdk/knowledge-schema": ["../../packages/knowledge-schema/src/index.ts"],
      "ink-surface-sdk/runtime-schema": ["../../packages/runtime-schema/src/index.ts"],
      "ink-surface-sdk/offline-store": ["../../packages/offline-store/src/index.ts"],
      "ink-surface-sdk/offline-store/indexeddb": ["../../packages/offline-store/src/indexeddb-store.ts"],
      "ink-surface-sdk/offline-store/file-sidecar": ["../../packages/offline-store/src/file-sidecar-store.ts"],
      "ink-surface-sdk/sync-client": ["../../packages/sync-client/src/index.ts"],
      "ink-surface-sdk/surface-model": ["../../packages/surface-model/src/index.ts"],
      "ink-surface-sdk/export-core": ["../../packages/export-core/src/index.ts"],
      "ink-surface-sdk/adapters/obsidian": ["../../packages/adapter-obsidian/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["server", "scripts", "vite.config.ts"]
}
