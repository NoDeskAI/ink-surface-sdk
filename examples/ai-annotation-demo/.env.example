# 复制为 .env 后填入真实网关 Key：cp .env.example .env
LLM_GATEWAY_URL=https://llm-gateway-api.nodesk.tech/default/v1
LLM_GATEWAY_KEY=
LLM_GATEWAY_TRANSPORT=chat_completions
LLM_MODEL=glm-5.2

# 飞书机器人应用身份（日历/会议安排读取）。不要提交真实密钥。
# 运行时也可通过 Cloud Hub 的 /api/feishu/bot/config 写入本地配置文件覆盖这里的默认值。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
INKLOOP_FEISHU_BOT_CONFIG=.inkloop/feishu-bot-config.json

# 教育课堂实时转写。默认留空时录音仍保存，但字幕进入明确降级状态。
# local 模式只允许 loopback/private 地址；external 模式要求 HTTPS、服务端 opt-in，且教师每次录音仍需在 UI 明示同意。
INKLOOP_CLASSROOM_TRANSCRIPTION_URL=http://127.0.0.1:8178/v1/transcribe
INKLOOP_CLASSROOM_TRANSCRIPTION_MODE=local
# serve:classroom:https 默认会在本机启动 whisper.cpp；先运行 npm run setup:classroom-transcription
# INKLOOP_WHISPER_MODEL=.inkloop/models/ggml-base.bin
# INKLOOP_WHISPER_CLI=/opt/homebrew/bin/whisper-cli
# INKLOOP_CLASSROOM_TRANSCRIPTION_LOCAL=0
INKLOOP_CLASSROOM_TRANSCRIPTION_EXTERNAL_OPT_IN=0
INKLOOP_CLASSROOM_TRANSCRIPTION_API_KEY=

# 可选的本地完整教材。仓库默认使用 InkLoop 自制讲义；未获授权教材不要提交或发布。
# INKLOOP_CLASSROOM_TEXTBOOK_PATH=/absolute/path/to/textbook.pdf

# 外部生成式 AI 默认关闭。开启会把完成任务所需的已确认板书/字幕片段发送到所配置网关；
# 部署方必须先完成教师授权流程与供应商数据条款披露。
INKLOOP_CLASSROOM_EXTERNAL_AI_ENABLED=0
