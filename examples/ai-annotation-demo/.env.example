# 复制为 .env 后填入真实网关 Key：cp .env.example .env
LLM_GATEWAY_URL=https://llm-gateway-api.nodesk.tech/default/v1
LLM_GATEWAY_KEY=
LLM_GATEWAY_TRANSPORT=chat_completions
LLM_MODEL=glm-5.2

# 飞书机器人应用身份（日历/会议安排读取）。不要提交真实密钥。
# 运行时也可通过 Cloud Hub 的 /api/feishu/bot/config 写入本地配置文件覆盖这里的默认值。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
INKLOOP_FEISHU_BOT_CONFIG=.inkloop/feishu-bot-config.json

# Zoom Server-to-Server OAuth
# 在 Zoom App Marketplace 创建 Server-to-Server OAuth app，从 App Credentials 复制以下三项；不要提交真实密钥。
# 最小 scopes：meeting:read:admin、recording:read:admin；未设置 ZOOM_HOST_USER_IDS 并启用主持人自动发现时还需 user:read:admin。
ZOOM_S2S_ACCOUNT_ID=
ZOOM_S2S_CLIENT_ID=
ZOOM_S2S_CLIENT_SECRET=
# 逗号分隔的 Zoom user id 或 email。留空时自动发现 Licensed 用户，最多 10 个。
ZOOM_HOST_USER_IDS=
# 实验性的 Meeting Transcript API 对比探测；默认开启，经典云录制 VTT 仍是主产物。
ZOOM_MEETING_TRANSCRIPT_PROBE=1
# Zoom 排期快照与会后记录状态文件；相对路径以 demo 宿主工作目录为基准。
ZOOM_SYNC_STATE_PATH=.inkloop/zoom-sync/state.json
ZOOM_RECORDS_STATE_PATH=.inkloop/zoom-records/state.json
