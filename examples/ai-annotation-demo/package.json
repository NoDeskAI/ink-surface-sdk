{
  "name": "inkloop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-pdfjs-assets.mjs && vite",
    "build": "node scripts/copy-pdfjs-assets.mjs && npm run check && vite build",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:ci": "biome check --error-on-warnings .",
    "format": "biome format --write .",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run check && npm run lint:ci && npm run test && vite build && npm run verify:android-paper-assets && npm run smoke:runtime-sync-flow && npm run smoke:ai-pen-v1 && npm run smoke:ai-graph-worker && npm run smoke:ai-pen-evidence && npm run smoke:capture-surface-evidence && npm run smoke:live-board-latency-evidence && npm run smoke:reward-pricing-evidence && npm run smoke:gtm-metrics-evidence && npm run smoke:demo-review-evidence",
    "verify:v1-product": "npm run check && npm run smoke:runtime-sync-flow && npm run smoke:cloud-hub-device-session && npm run smoke:cloud-hub-device-status && npm run smoke:cloud-hub-multi-user && npm run smoke:cloud-hub-controlled-writeback && npm run smoke:obsidian-reading-kind-coverage && npm run verify:reader-reflow-trust-loop && npm run smoke:v1-product-e2e && npm run smoke:meeting-v1-e2e",
    "verify:v1-product:paper": "npm run verify:v1-product && npm run smoke:m103-web-import-formats-device && npm run smoke:m103-lan-import-formats-device && npm run smoke:m103-cloud-library-device && npm run smoke:paper-reading-mark-types-device && npm run smoke:m103-meeting-device",
    "audit:v1-product-acceptance": "tsx scripts/verify-v1-product-acceptance.ts",
    "preview": "vite preview",
    "evidence:ai-pen-run": "tsx scripts/analyze-ai-pen-run.ts",
    "evidence:capture-surface": "tsx scripts/analyze-capture-surface-calibration.ts",
    "evidence:live-board-latency": "tsx scripts/analyze-live-board-latency.ts",
    "evidence:reward-pricing": "tsx scripts/analyze-reward-pricing.ts",
    "evidence:gtm-metrics": "tsx scripts/analyze-gtm-metrics.ts",
    "evidence:demo-review": "tsx scripts/analyze-demo-review.ts",
    "verify:android-paper-assets": "node scripts/sync-android-assets.mjs && node scripts/verify-android-paper-assets.mjs",
    "smoke:runtime-sync-flow": "tsx scripts/smoke-runtime-sync-flow.ts",
    "smoke:v1-product-e2e": "tsx scripts/verify-v1-product-e2e.ts",
    "smoke:cloud-hub-multi-user": "tsx scripts/verify-cloud-hub-multi-user-isolation.ts",
    "smoke:cloud-hub-device-session": "tsx scripts/verify-cloud-hub-device-session-binding.ts",
    "smoke:cloud-hub-local-device-auth": "tsx scripts/verify-cloud-hub-local-device-auth.ts",
    "smoke:cloud-hub-controlled-writeback": "tsx scripts/verify-cloud-hub-controlled-writeback.ts",
    "smoke:cloud-hub-device-status": "tsx scripts/verify-cloud-hub-device-status.ts",
    "smoke:obsidian-reading-kind-coverage": "tsx scripts/verify-obsidian-reading-kind-coverage.ts",
    "smoke:paper-reading-mark-types-device": "INKLOOP_DEVICE_ID=paper-reading-mark-types INKLOOP_DEVICE_LABEL='Paper reading mark type verification' tsx scripts/verify-m103-reading-mark-types-device.ts",
    "smoke:paper-stylus-input": "tsx scripts/verify-paper-stylus-input-device.ts",
    "smoke:paper-stylus-input:live": "PAPER_STYLUS_INPUT_TIMEOUT_MS=45000 tsx scripts/verify-paper-stylus-input-device.ts",
    "smoke:paper-stylus-input:synthetic": "PAPER_STYLUS_INPUT_TIMEOUT_MS=5000 PAPER_STYLUS_INJECT_SYNTHETIC=1 tsx scripts/verify-paper-stylus-input-device.ts",
    "smoke:m103-cloud-library-device": "tsx scripts/verify-m103-cloud-library-device.ts",
    "smoke:m103-reading-mark-types-device": "tsx scripts/verify-m103-reading-mark-types-device.ts",
    "smoke:m103-meeting-device": "tsx scripts/verify-m103-meeting-device.ts",
    "smoke:m103-web-import-formats-device": "tsx scripts/verify-m103-web-import-formats-device.ts",
    "smoke:m103-stylus-input": "tsx scripts/verify-m103-stylus-input-device.ts",
    "smoke:m103-stylus-input:live": "M103_STYLUS_INPUT_TIMEOUT_MS=45000 tsx scripts/verify-m103-stylus-input-device.ts",
    "smoke:m103-stylus-input:synthetic": "M103_STYLUS_INPUT_TIMEOUT_MS=5000 M103_STYLUS_INJECT_SYNTHETIC=1 tsx scripts/verify-m103-stylus-input-device.ts",
    "smoke:m103-input-health": "tsx scripts/verify-m103-input-health-device.ts",
    "smoke:m103-input-health:synthetic": "M103_INPUT_HEALTH_TIMEOUT_MS=5000 M103_INPUT_HEALTH_INJECT_SYNTHETIC=1 tsx scripts/verify-m103-input-health-device.ts",
    "smoke:m103-physical-pen-capture": "tsx scripts/verify-m103-physical-pen-capture-device.ts",
    "smoke:m103-physical-pen-synthetic": "M103_PEN_INJECT_SYNTHETIC=1 tsx scripts/verify-m103-physical-pen-capture-device.ts",
    "smoke:m103-lan-import-device": "tsx scripts/verify-m103-lan-import-device.ts",
    "smoke:m103-lan-import-formats-device": "tsx scripts/verify-m103-lan-import-formats-device.ts",
    "smoke:meeting-v1-e2e": "tsx scripts/verify-meeting-v1-e2e.ts",
    "smoke:meeting-real-feishu-e2e": "tsx scripts/verify-real-feishu-meeting-e2e.ts",
    "backfill:cloud-library-covers": "tsx scripts/backfill-cloud-library-covers.ts",
    "seed:reading-demo-output": "tsx scripts/seed-reading-demo-output.ts",
    "verify:reflow-text": "tsx scripts/verify-reflow-text-integrity.ts",
    "verify:reader-reflow-falsification": "tsx scripts/verify-reader-reflow-falsification.ts",
    "verify:reader-reflow-trust-loop": "tsx scripts/verify-reader-reflow-trust-loop.ts",
    "smoke:ai-pen-v1": "tsx scripts/smoke-ai-pen-v1.ts",
    "smoke:ai-graph-worker": "tsx scripts/smoke-ai-graph-worker.ts",
    "smoke:ai-pen-evidence": "tsx scripts/analyze-ai-pen-run.ts fixtures/ai-pen-run-sample.jsonl",
    "smoke:capture-surface-evidence": "tsx scripts/analyze-capture-surface-calibration.ts fixtures/capture-surface-calibration-sample.csv",
    "smoke:live-board-latency-evidence": "tsx scripts/analyze-live-board-latency.ts fixtures/live-board-latency-sample.csv",
    "smoke:reward-pricing-evidence": "tsx scripts/analyze-reward-pricing.ts fixtures/reward-pricing-sample.csv",
    "smoke:gtm-metrics-evidence": "tsx scripts/analyze-gtm-metrics.ts fixtures/gtm-metrics-sample.csv",
    "smoke:demo-review-evidence": "tsx scripts/analyze-demo-review.ts fixtures/demo-review-sample.csv",
    "smoke:ai-pen-browser": "vite build && tsx scripts/smoke-ai-pen-browser.ts",
    "serve": "tsx server/standalone.ts",
    "serve:lark-sdk": "node scripts/start-lark-meeting-sdk.mjs",
    "postinstall": "node scripts/copy-pdfjs-assets.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "ink-surface-sdk": "file:../..",
    "pdfjs-dist": "^4.6.82",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.7.4",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
