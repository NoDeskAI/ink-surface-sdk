{
  "name": "ink-surface-sdk-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/ink-surface-sdk"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run check && vite build && npm run build:sdk",
    "build:sdk": "npm run build -w ink-surface-sdk",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit && npm run check -w ink-surface-sdk",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:ci": "biome check --error-on-warnings .",
    "format": "biome format --write .",
    "audit": "npm audit --audit-level=high",
    "validate:fixtures": "tsx scripts/validate-fixtures.ts",
    "obsidian:smoke": "tsx scripts/smoke-real-obsidian-flow.ts",
    "inkloop-adapter": "tsx src/adapters/obsidian-fs/cli.ts",
    "obsidian:install-plugin": "node scripts/install-obsidian-plugin.mjs",
    "verify": "npm run check && npm run lint:ci && npm run test && vite build && npm run build:sdk",
    "preview": "vite preview",
    "serve": "tsx server/standalone.ts",
    "postinstall": "node scripts/copy-pdfjs-assets.mjs"
  },
  "dependencies": {
    "ink-surface-sdk": "file:packages/ink-surface-sdk",
    "pdfjs-dist": "^4.6.82",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.7.4",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
