{
  "name": "ink-surface-sdk",
  "version": "0.1.0",
  "description": "InkLoop AI Pen runtime, system contracts, validation hosts, and the InkSurface SDK renderer.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/inkloop-surface-sdk.es.js",
  "module": "./dist/inkloop-surface-sdk.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/inkloop-surface-sdk.es.js",
      "default": "./dist/inkloop-surface-sdk.es.js"
    },
    "./adapter-contracts": {
      "types": "./dist/packages/adapter-contracts/src/index.d.ts",
      "import": "./dist/packages/adapter-contracts/src/index.js",
      "default": "./dist/packages/adapter-contracts/src/index.js"
    },
    "./adapters/obsidian": {
      "types": "./dist/packages/adapter-obsidian/src/index.d.ts",
      "import": "./dist/packages/adapter-obsidian/src/index.js",
      "default": "./dist/packages/adapter-obsidian/src/index.js"
    },
    "./export-core": {
      "types": "./dist/packages/export-core/src/index.d.ts",
      "import": "./dist/packages/export-core/src/index.js",
      "default": "./dist/packages/export-core/src/index.js"
    },
    "./knowledge-schema": {
      "types": "./dist/packages/knowledge-schema/src/index.d.ts",
      "import": "./dist/packages/knowledge-schema/src/index.js",
      "default": "./dist/packages/knowledge-schema/src/index.js"
    },
    "./native-bridge": {
      "types": "./dist/packages/native-bridge/src/index.d.ts",
      "import": "./dist/packages/native-bridge/src/index.js",
      "default": "./dist/packages/native-bridge/src/index.js"
    },
    "./offline-store": {
      "types": "./dist/packages/offline-store/src/index.d.ts",
      "import": "./dist/packages/offline-store/src/index.js",
      "default": "./dist/packages/offline-store/src/index.js"
    },
    "./offline-store/file-sidecar": {
      "types": "./dist/packages/offline-store/src/file-sidecar-store.d.ts",
      "import": "./dist/packages/offline-store/src/file-sidecar-store.js",
      "default": "./dist/packages/offline-store/src/file-sidecar-store.js"
    },
    "./offline-store/indexeddb": {
      "types": "./dist/packages/offline-store/src/indexeddb-store.d.ts",
      "import": "./dist/packages/offline-store/src/indexeddb-store.js",
      "default": "./dist/packages/offline-store/src/indexeddb-store.js"
    },
    "./runtime-schema": {
      "types": "./dist/packages/runtime-schema/src/index.d.ts",
      "import": "./dist/packages/runtime-schema/src/index.js",
      "default": "./dist/packages/runtime-schema/src/index.js"
    },
    "./surface-model": {
      "types": "./dist/packages/surface-model/src/index.d.ts",
      "import": "./dist/packages/surface-model/src/index.js",
      "default": "./dist/packages/surface-model/src/index.js"
    },
    "./surface-web": {
      "types": "./dist/packages/surface-web/src/index.d.ts",
      "import": "./dist/packages/surface-web/src/index.js",
      "default": "./dist/packages/surface-web/src/index.js"
    },
    "./sync-client": {
      "types": "./dist/packages/sync-client/src/index.d.ts",
      "import": "./dist/packages/sync-client/src/index.js",
      "default": "./dist/packages/sync-client/src/index.js"
    },
    "./iife": "./dist/inkloop-surface-sdk.iife.js"
  },
  "files": [
    "dist",
    "src/index.ts",
    "apps/sync-api/README.md",
    "apps/sync-api/contracts",
    "packages/adapter-contracts/package.json",
    "packages/adapter-contracts/src/index.ts",
    "packages/adapter-contracts/README.md",
    "packages/adapter-obsidian/package.json",
    "packages/adapter-obsidian/src/index.ts",
    "packages/adapter-obsidian/README.md",
    "packages/export-core/package.json",
    "packages/export-core/src/index.ts",
    "packages/export-core/README.md",
    "packages/knowledge-schema/package.json",
    "packages/knowledge-schema/src/index.ts",
    "packages/knowledge-schema/README.md",
    "packages/native-bridge/package.json",
    "packages/native-bridge/src/index.ts",
    "packages/native-bridge/src/webview-host.md",
    "packages/native-bridge/src/offline-state-matrix.md",
    "packages/native-bridge/README.md",
    "packages/offline-store/package.json",
    "packages/offline-store/src/index.ts",
    "packages/offline-store/src/file-sidecar-store.ts",
    "packages/offline-store/src/indexeddb-store.ts",
    "packages/offline-store/README.md",
    "packages/runtime-schema/package.json",
    "packages/runtime-schema/src/index.ts",
    "packages/runtime-schema/src/schema-versioning.md",
    "packages/runtime-schema/src/fixtures",
    "packages/runtime-schema/README.md",
    "packages/surface-model/package.json",
    "packages/surface-model/src/index.ts",
    "packages/surface-model/README.md",
    "packages/sync-client/package.json",
    "packages/sync-client/src/index.ts",
    "packages/sync-client/README.md",
    "packages/surface-web/package.json",
    "packages/surface-web/src/index.ts",
    "packages/surface-web/README.md",
    "plugins/obsidian/inkloop-sync",
    "native/ios/README.md",
    "native/android/README.md",
    "scripts/build-obsidian-plugin.mjs",
    "scripts/finalize-types.mjs",
    "scripts/install-obsidian-plugin.mjs",
    "README.md",
    "docs/ink-surface-sdk.md",
    "docs/architecture.md",
    "docs/cross-platform-offline-runtime.md",
    "docs/platform-renderer-strategy.md",
    "tsconfig.packages.json"
  ],
  "workspaces": [
    "packages/*",
    "examples/ai-annotation-demo"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.packages.json && tsc -p tsconfig.build.json && node scripts/finalize-types.mjs && node scripts/build-obsidian-plugin.mjs",
    "build:obsidian-plugin": "node scripts/build-obsidian-plugin.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:ci": "biome check --error-on-warnings .",
    "format": "biome format --write .",
    "audit": "npm audit --audit-level=high",
    "pack:check": "npm pack --dry-run --json",
    "verify:consumer": "node scripts/verify-package-consumer.mjs",
    "verify:ai-pen-kickstarter": "node scripts/verify-ai-pen-kickstarter.mjs",
    "verify:obsidian-v1-plugin": "node scripts/verify-obsidian-v1-plugin.mjs",
    "verify:kickstarter-claims": "node scripts/verify-kickstarter-campaign-claims.mjs",
    "verify:local-demo-handoff": "npm run demo:smoke:runtime-sync && npm run demo:smoke:ai-pen && npm run demo:smoke:ai-graph-worker && npm run android:assemble:debug:local-demo && npm run obsidian:demo-vault && npm run kickstarter:ops-refresh && npm run demo:evidence:bundle",
    "launch:evidence:audit": "node scripts/audit-launch-evidence.mjs",
    "launch:evidence:audit:strict": "node scripts/audit-launch-evidence.mjs --strict",
    "launch:evidence:intake": "node scripts/create-launch-evidence-intake.mjs",
    "launch:evidence:intake-audit": "node scripts/audit-launch-evidence-intake.mjs",
    "launch:evidence:intake-audit:strict": "node scripts/audit-launch-evidence-intake.mjs --strict",
    "launch:evidence:record-update-plan": "node scripts/build-launch-evidence-record-update-plan.mjs",
    "launch:evidence:record-update-plan:strict": "node scripts/build-launch-evidence-record-update-plan.mjs --strict",
    "launch:evidence:apply-record-updates": "node scripts/apply-launch-evidence-record-updates.mjs",
    "launch:evidence:apply-record-updates:write": "node scripts/apply-launch-evidence-record-updates.mjs --apply",
    "launch:evidence:apply-record-updates:strict": "node scripts/apply-launch-evidence-record-updates.mjs --strict",
    "launch:action-plan": "node scripts/build-launch-action-plan.mjs",
    "launch:critical-path": "node scripts/build-kickstarter-critical-path.mjs",
    "launch:critical-path:strict": "node scripts/build-kickstarter-critical-path.mjs --strict",
    "launch:weekly-sprint": "node scripts/build-kickstarter-weekly-sprint.mjs",
    "launch:weekly-sprint:strict": "node scripts/build-kickstarter-weekly-sprint.mjs --strict",
    "launch:kpi-dashboard": "node scripts/build-launch-kpi-dashboard.mjs",
    "launch:kpi-dashboard:strict": "node scripts/build-launch-kpi-dashboard.mjs --strict",
    "launch:review-pack": "node scripts/build-launch-review-pack.mjs",
    "launch:operator-pack": "node scripts/build-launch-operator-pack.mjs",
    "launch:operator-pack:strict": "node scripts/build-launch-operator-pack.mjs --strict",
    "kickstarter:rehearsal-pack": "node scripts/build-kickstarter-rehearsal-pack.mjs",
    "kickstarter:claim-downgrade": "node scripts/build-kickstarter-claim-downgrade-pack.mjs",
    "kickstarter:claim-downgrade:strict": "node scripts/build-kickstarter-claim-downgrade-pack.mjs --strict",
    "kickstarter:public-copy-lock": "node scripts/build-kickstarter-public-copy-lock.mjs",
    "kickstarter:public-copy-lock:strict": "node scripts/build-kickstarter-public-copy-lock.mjs --strict",
    "kickstarter:supplier-quote-intake": "node scripts/create-kickstarter-supplier-quote-intake.mjs",
    "kickstarter:supplier-quote-audit": "node scripts/audit-kickstarter-supplier-quotes.mjs",
    "kickstarter:supplier-quote-audit:strict": "node scripts/audit-kickstarter-supplier-quotes.mjs --strict",
    "kickstarter:page-review-intake": "node scripts/create-kickstarter-page-review-intake.mjs",
    "kickstarter:page-review-audit": "node scripts/audit-kickstarter-page-review.mjs",
    "kickstarter:page-review-audit:strict": "node scripts/audit-kickstarter-page-review.mjs --strict",
    "kickstarter:launch-signoff-audit": "node scripts/audit-kickstarter-launch-signoff.mjs",
    "kickstarter:launch-signoff-audit:strict": "node scripts/audit-kickstarter-launch-signoff.mjs --strict",
    "kickstarter:prelaunch-page-intake": "node scripts/create-kickstarter-prelaunch-page-intake.mjs",
    "kickstarter:prelaunch-page-intake-audit": "node scripts/audit-kickstarter-prelaunch-page-intake.mjs",
    "kickstarter:prelaunch-page-intake-audit:strict": "node scripts/audit-kickstarter-prelaunch-page-intake.mjs --strict",
    "kickstarter:prelaunch-page-pack": "node scripts/build-kickstarter-prelaunch-page-pack.mjs",
    "kickstarter:prelaunch-page-pack:strict": "node scripts/build-kickstarter-prelaunch-page-pack.mjs --strict",
    "kickstarter:risk-register": "node scripts/build-kickstarter-risk-register.mjs",
    "kickstarter:risk-register:strict": "node scripts/build-kickstarter-risk-register.mjs --strict",
    "kickstarter:ops-refresh": "node scripts/run-kickstarter-ops-refresh.mjs",
    "kickstarter:ops-refresh:strict": "node scripts/run-kickstarter-ops-refresh.mjs --strict",
    "kickstarter:p0-command-brief": "node scripts/build-kickstarter-p0-command-brief.mjs",
    "kickstarter:launch-freeze-pack": "node scripts/build-kickstarter-launch-freeze-pack.mjs",
    "kickstarter:launch-freeze-pack:strict": "node scripts/build-kickstarter-launch-freeze-pack.mjs --strict",
    "kickstarter:launch-day-command-center": "node scripts/build-kickstarter-launch-day-command-center.mjs",
    "kickstarter:launch-day-command-center:strict": "node scripts/build-kickstarter-launch-day-command-center.mjs --strict",
    "kickstarter:proof-shot-intake": "node scripts/create-kickstarter-proof-shot-intake.mjs",
    "kickstarter:proof-shot-audit": "node scripts/audit-kickstarter-proof-shots.mjs",
    "kickstarter:proof-shot-audit:strict": "node scripts/audit-kickstarter-proof-shots.mjs --strict",
    "verify": "npm run check && npm run lint:ci && npm run verify:ai-pen-kickstarter && npm run verify:kickstarter-claims && npm run test && npm run build && npm run verify:obsidian-v1-plugin && node scripts/create-obsidian-demo-vault.mjs --skip-build && npm run pack:check && npm run verify:consumer && npm run demo:verify",
    "demo:dev": "npm --workspace ./examples/ai-annotation-demo run dev --",
    "cloud-hub:up": "docker compose -f docker-compose.cloud-hub.yml up -d --build",
    "cloud-hub:logs": "docker compose -f docker-compose.cloud-hub.yml logs -f cloud-hub",
    "cloud-hub:down": "docker compose -f docker-compose.cloud-hub.yml down",
    "demo:ai-pen": "node scripts/run-ai-pen-demo.mjs",
    "demo:build": "npm --workspace ./examples/ai-annotation-demo run build",
    "demo:check": "npm --workspace ./examples/ai-annotation-demo run check",
    "demo:test": "npm --workspace ./examples/ai-annotation-demo run test",
    "demo:verify": "npm --workspace ./examples/ai-annotation-demo run verify",
    "demo:verify:v1-product": "npm --workspace ./examples/ai-annotation-demo run verify:v1-product",
    "demo:verify:v1-product:paper": "npm --workspace ./examples/ai-annotation-demo run verify:v1-product:paper",
    "demo:audit:v1-product-acceptance": "npm --workspace ./examples/ai-annotation-demo run audit:v1-product-acceptance",
    "demo:smoke:runtime-sync": "npm --workspace ./examples/ai-annotation-demo run smoke:runtime-sync-flow",
    "demo:smoke:ai-pen": "npm --workspace ./examples/ai-annotation-demo run smoke:ai-pen-browser",
    "demo:smoke:ai-graph-worker": "npm --workspace ./examples/ai-annotation-demo run smoke:ai-graph-worker",
    "demo:evidence:bundle": "node scripts/build-demo-evidence-bundle.mjs",
    "android:assemble:debug": "node scripts/assemble-android-paper-debug.mjs",
    "android:assemble:debug:local-demo": "INKLOOP_ANDROID_LOCAL_DEMO_AUTH=1 node scripts/assemble-android-paper-debug.mjs",
    "demo:preview": "npm --workspace ./examples/ai-annotation-demo run preview --",
    "obsidian:smoke": "npm run build && npm run verify:obsidian-v1-plugin",
    "obsidian:demo-vault": "node scripts/create-obsidian-demo-vault.mjs",
    "obsidian:install-plugin": "node scripts/install-obsidian-plugin.mjs",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.7.4",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.5.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
