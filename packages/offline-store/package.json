{
  "name": "@inksurface/offline-store",
  "private": true,
  "version": "0.1.0",
  "description": "Offline document cache state, runtime store ports, and eviction policy contracts for InkSurface hosts.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./file-sidecar": {
      "types": "./src/file-sidecar-store.ts",
      "import": "./src/file-sidecar-store.ts",
      "default": "./src/file-sidecar-store.ts"
    },
    "./indexeddb": {
      "types": "./src/indexeddb-store.ts",
      "import": "./src/indexeddb-store.ts",
      "default": "./src/indexeddb-store.ts"
    }
  }
}
